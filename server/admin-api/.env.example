# Copy this file to .env and fill values.
PORT=8787

# Same Supabase project URL as your Flutter app
SUPABASE_URL=https://qjjluaqlmckotxqeigtr.supabase.co

# Prefer the new secret key for server workloads.
# If omitted, fallback to SUPABASE_SERVICE_ROLE_KEY is used.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret to protect admin endpoints
ADMIN_API_TOKEN=change_me_to_a_long_random_value

# JWT signing secret (min 32 chars, random)
JWT_SECRET=change_me_to_a_long_random_jwt_secret_value

# Security defaults
# Keep local-only admin access unless you intentionally expose this API.
ALLOW_REMOTE_ADMIN=false

# Basic per-IP limiter for /admin/users/create
CREATE_USER_WINDOW_MS=60000
CREATE_USER_MAX_PER_WINDOW=10
